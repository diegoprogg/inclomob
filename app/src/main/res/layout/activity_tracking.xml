<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app">

    <!-- Header Azul -->
    <View
        android:id="@+id/header_bg"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:background="@color/accent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/btn_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@android:drawable/ic_menu_revert"
        app:tint="#FFFFFF"
        android:layout_marginTop="24dp"
        android:layout_marginStart="24dp"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/circle_bg_translucent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/badge_live"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AO VIVO"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:background="@drawable/badge_bg_translucent"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txt_line_id"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1062"
        android:textColor="#FFFFFF"
        android:textSize="56sp"
        android:textStyle="bold"
        android:layout_marginTop="80dp"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/txt_tracking_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Acompanhamento em tempo real"
        android:textColor="#E0E7FF"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/txt_line_id"
        app:layout_constraintStart_toStartOf="@id/txt_line_id" />

    <!-- Card de Conteúdo (Timeline) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="-40dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/bg_card"
        app:layout_constraintTop_toBottomOf="@id/header_bg"
        app:layout_constraintBottom_toTopOf="@id/bottom_actions_container">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="32dp">

            <!-- Linha Vertical da Timeline -->
            <View
                android:id="@+id/timeline_line"
                android:layout_width="2dp"
                android:layout_height="0dp"
                android:background="@color/accent"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"
                app:layout_constraintTop_toTopOf="@id/icon_user"
                app:layout_constraintBottom_toBottomOf="@id/icon_eta"
                app:layout_constraintStart_toStartOf="@id/icon_user"
                app:layout_constraintEnd_toEndOf="@id/icon_user" />

            <!-- Item 1: Localização -->
            <ImageView
                android:id="@+id/icon_user"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_mylocation"
                app:tint="@color/accent"
                android:background="@drawable/circle_bg_white"
                android:padding="6dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                app:layout_constraintTop_toTopOf="@id/icon_user"
                app:layout_constraintBottom_toBottomOf="@id/icon_user"
                app:layout_constraintStart_toEndOf="@id/icon_user"
                app:layout_constraintEnd_toEndOf="parent">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/your_location"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/updated_now"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Item 2: Ônibus -->
            <ImageView
                android:id="@+id/icon_bus"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_directions"
                app:tint="#FFFFFF"
                android:background="@drawable/circle_bg_accent"
                android:padding="6dp"
                android:layout_marginTop="48dp"
                app:layout_constraintTop_toBottomOf="@id/icon_user"
                app:layout_constraintStart_toStartOf="parent" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                app:layout_constraintTop_toTopOf="@id/icon_bus"
                app:layout_constraintBottom_toBottomOf="@id/icon_bus"
                app:layout_constraintStart_toEndOf="@id/icon_bus"
                app:layout_constraintEnd_toEndOf="parent">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bus_moving"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />
                <TextView
                    android:id="@+id/txt_bus_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0m de distância • 0.0 km/h"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Item 3: ETA -->
            <ImageView
                android:id="@+id/icon_eta"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_recent_history"
                app:tint="@color/text_muted"
                android:background="@drawable/circle_bg_muted"
                android:padding="6dp"
                android:layout_marginTop="48dp"
                app:layout_constraintTop_toBottomOf="@id/icon_bus"
                app:layout_constraintStart_toStartOf="parent" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                app:layout_constraintTop_toTopOf="@id/icon_eta"
                app:layout_constraintBottom_toBottomOf="@id/icon_eta"
                app:layout_constraintStart_toEndOf="@id/icon_eta"
                app:layout_constraintEnd_toEndOf="parent">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/estimated_arrival"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />
                <TextView
                    android:id="@+id/txt_eta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/calculating"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- Container do Botão de Pulseira e Microfone -->
    <LinearLayout
        android:id="@+id/bottom_actions_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="@color/bg_card"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_connect_bracelet"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="Conectar pulseira inteligente"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_menu_share"
            app:iconGravity="textStart"
            app:backgroundTint="@color/accent" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_voice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:src="@android:drawable/ic_btn_speak_now"
            app:backgroundTint="@color/accent"
            app:tint="#FFFFFF"
            app:fabSize="normal"
            app:elevation="4dp" />
    </LinearLayout>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/bottom_nav_bg"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_house"
                app:tint="@color/accent" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_home"
                android:textColor="@color/accent"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_config"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_preferences"
                app:tint="@color/text_muted" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_config"
                android:textColor="@color/text_muted"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
